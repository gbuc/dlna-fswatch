#!/bin/bash
# MiniDLNA Watcher Configuration
# Edit these values before running install.sh

# Path to minidlna.conf - if set, MEDIA_DIRS and MINIDLNA_CACHE_DIR will be read from it
MINIDLNA_CONF="/opt/homebrew/etc/minidlna.conf"

# Where minidlna stores its cache/database (ignored if MINIDLNA_CONF is set)
MINIDLNA_CACHE_DIR="/path/to/minidlna/cache"

# Directories to watch for new downloads (ignored if MINIDLNA_CONF is set)
MEDIA_DIRS=(
    "/path/to/your/downloads"
    "/path/to/your/media"
)

# Where to install the watcher script
INSTALL_DIR="$HOME/.config/minidlna"

# Inactivity timeout in seconds before triggering refresh
INACTIVITY_TIMEOUT=60

# Path to homebrew (adjust for Intel Macs: /usr/local/bin)
HOMEBREW_PREFIX="/opt/homebrew/bin"
